From d1d4f8a6ba375ce32a1f09ba58e1dd9ab27cc955 Mon Sep 17 00:00:00 2001
From: Ramesh Mandal <ramesh@6epixels.com>
Date: Thu, 2 Jul 2026 14:22:41 +0000
Subject: [PATCH] fix(chat): blank screen when opening a new conversation

The messages selector fell back to a fresh '?? []' array when a
conversation had no messages yet (any chat newly started from Contacts).
useSyncExternalStore saw a new snapshot reference every render and
looped until React bailed, leaving a white panel.

- ChatView: select against a stable NO_MESSAGES constant
- chat.store: startConversation initializes an empty thread entry
---
 .../src/features/workspace/views/chat/ChatView.tsx        | 8 +++++++-
 apps/extension/src/stores/chat.store.ts                   | 1 +
 2 files changed, 8 insertions(+), 1 deletion(-)

diff --git a/apps/extension/src/features/workspace/views/chat/ChatView.tsx b/apps/extension/src/features/workspace/views/chat/ChatView.tsx
index 5bdf9c5..8769870 100644
--- a/apps/extension/src/features/workspace/views/chat/ChatView.tsx
+++ b/apps/extension/src/features/workspace/views/chat/ChatView.tsx
@@ -15,6 +15,12 @@ const presenceColors = {
   offline: "bg-slate-300",
 } as const;
 
+/**
+ * Stable fallback so the selector never returns a fresh reference.
+ * A new `?? []` per call makes useSyncExternalStore loop -> blank screen.
+ */
+const NO_MESSAGES: Message[] = [];
+
 function MessageBubble({ message }: { message: Message }) {
   const isMine = message.authorId === ME;
 
@@ -74,7 +80,7 @@ export default function ChatView({
   const contacts = useChatStore((state) => state.contacts);
   const conversations = useChatStore((state) => state.conversations);
   const messages = useChatStore(
-    (state) => state.messages[conversationId] ?? []
+    (state) => state.messages[conversationId] ?? NO_MESSAGES
   );
   const typing = useChatStore((state) => state.typing);
 
diff --git a/apps/extension/src/stores/chat.store.ts b/apps/extension/src/stores/chat.store.ts
index 1b618d1..e1ce9a0 100644
--- a/apps/extension/src/stores/chat.store.ts
+++ b/apps/extension/src/stores/chat.store.ts
@@ -218,6 +218,7 @@ export const useChatStore = create<ChatState>()(
 
           set((state) => ({
             conversations: [conversation, ...state.conversations],
+            messages: { ...state.messages, [conversation.id]: [] },
             activeConversationId: conversation.id,
           }));
 
-- 
