+// ---- Floating pill: community actions directly on the page ------------
+
+interface PillCommunity {
+  id: string;
+  name: string;
+}
+
+let pillSelectedCommunityId: string | null = null;
+let pillExpanded = false;
+
+async function eligiblePillCommunities(): Promise<PillCommunity[]> {
+  const [profile, communities] = await Promise.all([
+    readStoredProfile(),
+    readStoredCommunities(),
+  ]);
+  if (!profile) return [];
+
+  const hidden = await readPillHidden();
+
+  return Object.values(communities)
+    .filter(
+      (community) =>
+        community.members.some((m) => m.username === profile.username) &&
+        !hidden.includes(community.id)
+    )
+    .map((community) => ({ id: community.id, name: community.name }));
+}
+
+async function readPillHidden(): Promise<string[]> {
+  const result = await browser.storage.local.get("tabcom:chat");
+  const raw = result["tabcom:chat"] as string | undefined;
+  if (!raw) return [];
+  try {
+    const parsed = JSON.parse(raw);
+    const state = parsed.state ?? parsed;
+    return Array.isArray(state.pillHidden) ? state.pillHidden : [];
+  } catch {
+    return [];
+  }
+}
+
+async function setupPill() {
+  const root = ensureShadowRoot();
+  root.querySelectorAll(".pill").forEach((el) => el.remove());
+
+  const communities = await eligiblePillCommunities();
+  if (communities.length === 0) {
+    stopCursorSharing();
+    return;
+  }
+
+  // Restore last selected community, or default to the first
+  const stored = await browser.storage.local.get("tabcom:pill:selected");
+  const remembered = stored["tabcom:pill:selected"] as string | undefined;
+  pillSelectedCommunityId =
+    communities.find((c) => c.id === remembered)?.id ?? communities[0].id;
+
+  const pill = document.createElement("div");
+  pill.className = "pill";
+
+  const toggle = document.createElement("button");
+  toggle.className = "pill-toggle";
+  toggle.textContent = "T";
+  toggle.title = "Tabcom — community actions";
+  toggle.addEventListener("click", () => {
+    pillExpanded = !pillExpanded;
+    renderPillPanel(pill, communities);
+  });
+
+  pill.append(toggle);
+  root.append(pill);
+
+  renderPillPanel(pill, communities);
+  void startCursorSharing();
+}
+
+function renderPillPanel(pill: HTMLElement, communities: PillCommunity[]) {
+  pill.querySelectorAll(".pill-panel").forEach((el) => el.remove());
+  if (!pillExpanded) return;
+
+  const panel = document.createElement("div");
+  panel.className = "pill-panel";
+
+  const head = document.createElement("div");
+  head.className = "pill-head";
+  head.textContent = "Tabcom";
+  panel.append(head);
+
+  if (communities.length > 1) {
+    const select = document.createElement("select");
+    select.className = "pill-select";
+    for (const community of communities) {
+      const option = document.createElement("option");
+      option.value = community.id;
+      option.textContent = community.name;
+      option.selected = community.id === pillSelectedCommunityId;
+      select.append(option);
+    }
+    select.addEventListener("change", () => {
+      pillSelectedCommunityId = select.value;
+      void browser.storage.local.set({ "tabcom:pill:selected": select.value });
+      stopCursorSharing();
+      void startCursorSharing();
+    });
+    panel.append(select);
+  }
+
+  const grid = document.createElement("div");
+  grid.className = "pill-grid";
+
+  const actions: Array<[string, () => void]> = [
+    [
+      "💬 Chat",
+      () => void browser.runtime.sendMessage({ type: "tabcom:open-panel" }),
+    ],
+    [
+      "➕ Add tab",
+      () => {
+        const anchor = readPageAnchor();
+        void boardWrite("item_add", {
+          communityId: pillSelectedCommunityId,
+          ...anchor,
+        });
+        pillExpanded = false;
+        renderPillPanel(pill, communities);
+      },
+    ],
+    [
+      "📍 Pin",
