# Postgres connection string. Get one free at https://neon.tech (or any
# Postgres host — Supabase, Railway, self-hosted, etc. all work the same
# way via this one standard connection string).
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Resend API key for sending real magic-link emails. Get one at
# https://resend.com. If this is unset, the server runs in dev mode:
# magic links are logged to the console instead of emailed — the full
# auth flow still works for local development and testing.
RESEND_API_KEY=

# The "from" address on magic-link emails. Must be a domain you've
# verified with Resend once you're sending real email.
MAIL_FROM="Tabcom <login@yourdomain.com>"

# The publicly reachable base URL of THIS server — used to build the
# link inside the magic-link email (e.g. https://api.yourdomain.com).
# Defaults to http://localhost:3001 if unset, which is correct for
# local development only.
# PUBLIC_BASE_URL=http://localhost:3001
WXT_REALTIME_URL=http://rameshs-macbook-pro.local:3001

# Tabcom is invite-only. This is the operator's master invitation
# code: multi-use, never stored in the database, rotatable by changing
# this value. Every account registered with it still gets its own 5
# single-use codes to hand out. If unset, only table codes work — and
# since the very first account has to come from SOMEWHERE, you almost
# certainly want this set.
TABCOM_MASTER_INVITE=TAB-MASTER-XXXX-XXXX
